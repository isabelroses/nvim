{
  "mks": {
    "prefix": "mkshell",
    "description": "Nix development shell",
    "body": [
      "{ mkShell }:",
      "mkShell {",
      "  buildInputs = [",
      "    $1",
      "  ];",
      "}"
    ]
  },
  "mod": {
    "prefix": "mod",
    "description": "Nix module",
    "body": [
      "{ lib, pkgs, config ... }:",
      "",
      "  let cfg = config;",
      "in {",
      "  config = lib.mkIf cfg.enable {",
      "    ${1:# code}",
      "  };",
      "}"
    ]
  }
}
